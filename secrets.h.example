#pragma once

// Copy this file to secrets.h and replace the placeholder values with
// your actual WiFi credentials and web auth password. secrets.h is
// listed in .gitignore so it will never be committed to the repository.
const char* WIFI_SSID     = "YOUR_SSID";
const char* WIFI_PASSWORD = "YOUR_PASSWORD";

// HTTP Basic Auth credentials for sensitive web endpoints (/update,
// /settings/reset, /settings/restore, device_restart).
// ⚠ WARNING: You MUST change WEB_AUTH_PASSWORD before deploying on
// your network. The default value here is intentionally weak — use a
// strong, unique password in your real secrets.h file.
const char* WEB_AUTH_USERNAME = "admin";
const char* WEB_AUTH_PASSWORD = "changeme";
